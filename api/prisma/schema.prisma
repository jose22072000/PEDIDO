generator client {
    provider   = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Sucursal {
    id        String    @id @default(cuid())
    nombre    String
    codigo    String?   @unique  // código de provincia (CAM, STG, TUN, ...); mapea con el consolidado y con Branch.externalId en delivery
    createdAt DateTime  @default(now())
    usuarios  Usuario[]
    vendedores Vendedor[]
    clientes   Cliente[]
    pedidos    Pedido[]
}

model Rol {
    id        String    @id @default(cuid())
    nombre    String    @unique @map("rol")
    createdAt DateTime  @default(now())
    usuarios  Usuario[]

    @@map("Roles")
}

model Usuario {
    id         String    @id @default(cuid())
    username   String    @unique
    password   String?
    rolId      String?   @map("roleId")
    rol        Rol?      @relation(fields: [rolId], references: [id])
    sucursalId String?
    sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])
    createdAt  DateTime  @default(now())

    @@map("User")
}

model Vendedor {
    id        String   @id @default(cuid())
    nombre    String   @map("name")
    codigo    String?  @map("code")
    sucursalId String?
    sucursal  Sucursal? @relation(fields: [sucursalId], references: [id])
    createdAt DateTime @default(now())
    pedidos   Pedido[]

    @@unique([sucursalId, nombre])
    @@unique([sucursalId, codigo])
    @@map("Seller")
}

model Pedido {
    id                 String       @id @default(cuid())
    folio              String
    sucursalId         String?
    sucursal           Sucursal?    @relation(fields: [sucursalId], references: [id])
    vendedorId         String?      @map("sellerId")
    vendedor           Vendedor?    @relation(fields: [vendedorId], references: [id])
    clienteId          String?      @map("clientId")
    cliente            Cliente?     @relation(fields: [clienteId], references: [id])
    direccion          String?
    encargado          String?
    telefono           String?
    fecha              DateTime
    fecha_comprometida DateTime?
    estado             String?      @map("status")
    pedido_cobrado     String?      @map("paymentStatus")
    requiere_domicilio Boolean?     @map("requiresDelivery")
    costoDomicilio     Float?       @map("deliveryCost")  // lo escribe delivery vía /integration
    createdAt          DateTime     @default(now())
    items              PedidoItem[]

    @@unique([sucursalId, folio, vendedorId])
    @@index([fecha])
    @@map("Order")
}

model PedidoItem {
    id          String  @id @default(cuid())
    pedidoId    String  @map("orderId")
    pedido      Pedido  @relation(fields: [pedidoId], references: [id])
    codigo      String? @map("code")
    producto    String
    unidades    Int
    packs       Int?    @default(0)
    descripcion String?

    @@map("OrderItem")
}

model Cliente {
    id        String   @id @default(cuid())
    codigo    String?  @map("parrandaId")
    sucursalId String?
    sucursal  Sucursal? @relation(fields: [sucursalId], references: [id])
    nombre    String
    zona      String?
    // Datos de geolocalización (del Consolidado_Geolocalizacion que entregó Parranda).
    // El CSV de pedidos NO los trae; se enriquecen a los clientes por nombre+sucursal.
    direccion       String?
    municipio       String?
    tipoCliente     String?  @map("clientType")      // Kiosko, Cafeteria, ...
    estadoCompra    String?  @map("purchaseStatus")  // "Compra" | "No Compra"
    latitud         Float?                           // usado por delivery para el cálculo de domicilio
    longitud        Float?
    geolocalizacion String?  @map("geoRaw")          // "lat,lng" crudo del consolidado
    createdAt DateTime @default(now())
    pedidos   Pedido[]

    @@unique([sucursalId, codigo])
    @@map("Client")
}
