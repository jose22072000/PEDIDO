# Development (SQLite)
NODE_ENV=development
PORT=8400
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/dev.db
JWT_SECRET=dev_secret_change_me
CORS_ORIGIN=*
# Clave compartida con delivery para /integration (x-api-key). MISMA en ambos.
SERVICE_API_KEY=cambia-esta-clave-compartida

