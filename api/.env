# API environment variables
# Points Prisma client to the local SQLite database (relative to repo root)
DATABASE_URL="file:./prisma/dev.db"

# API port
PORT=8400

# Node environment
NODE_ENV=development

# JWT Secret for token signature
JWT_SECRET=JFBOASOIDHBAUcioaboscboaishghebrfgiOPHGHFPAOISGHDB

# CORS configuration (comma-separated origins for multiple domains)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,http://localhost:3000
