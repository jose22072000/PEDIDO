# ============================================================================
#  PEDIDO — API   (Express + Prisma + PostgreSQL)     proceso pm2: procavar-api
# ----------------------------------------------------------------------------
#  En el VPS:  cp .env.vps.example .env   y rellena los CAMBIAR_*
#  Puerto que escucha: 8400
# ============================================================================

# --- Base de datos PostgreSQL ------------------------------------------------
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/BASE?schema=public
# La base en el VPS se llama `procovar_pedido` (así la crea initdb/01-databases.sql).
# En docker el host es `postgres`; suelto/local es `localhost`.
DATABASE_URL=postgresql://procovar:CAMBIAR_PASSWORD_DB@localhost:5432/procovar_pedido?schema=public
# Proveedor para el adaptador de Prisma. En prod: postgresql (NO sqlite).
DATABASE_PROVIDER=postgresql

# --- Servidor ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8400
NODE_ENV=production

# --- Seguridad ---------------------------------------------------------------
# Firma de los JWT de sesión. Genera uno nuevo y largo:  openssl rand -hex 48
JWT_SECRET=CAMBIAR_secreto_jwt_largo_aleatorio

# CORS. En prod pon tus dominios en vez de "*":
#   CORS_ORIGIN=https://pedidos.tudominio.com,https://delivery.tudominio.com
CORS_ORIGIN=*

# Clave servidor-a-servidor (delivery/analitics -> PEDIDO, header x-api-key).
# DEBE SER IDÉNTICA a la de delivery y analitics (todas usan SERVICE_API_KEY).
SERVICE_API_KEY=CAMBIAR_misma_clave_en_delivery_y_analitics

# --- Redis (eventos de entrada de pedidos: BullMQ) ---------------------------
# OPCIONAL: sin REDIS_URL (ni sentinel), PEDIDO arranca igual y el SSE cae a
# polling. Con REDIS_URL, el SSE pasa a pub/sub (canal procovar-pedido:orders:new).
# En docker: redis://redis:6379 (lo inyecta el compose). Suelto/local: localhost.
REDIS_URL=redis://localhost:6379
# Sentinel (HA multi-nodo) — dejar vacío para modo simple con REDIS_URL de arriba.
# Si se rellenan AMBOS, tienen prioridad sobre REDIS_URL.
#   REDIS_SENTINELS=host1:26379,host2:26379,host3:26379
#   REDIS_MASTER_NAME=procovar-master
REDIS_SENTINELS=
REDIS_MASTER_NAME=
# Cola de importación de CSV (Rebanada 2). OPT-IN explícito: solo con esto en 'true'
# el POST /orders/bulk ENCOLA (y REQUIERE el worker corriendo: node dist/worker.js).
# Sin esto, el import es inline aunque Redis esté activo para el SSE.
IMPORT_USE_QUEUE=false
# Cuántas importaciones procesa el worker a la vez (subir con más CPU/RAM).
IMPORT_CONCURRENCY=2
