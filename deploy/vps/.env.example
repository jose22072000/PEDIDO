# =============================================================================
#  Variables de entorno del bundle de PRODUCCION (docker compose)
# -----------------------------------------------------------------------------
#  Copia este archivo a `.env` en el mismo directorio que docker-compose.yml:
#
#      cp .env.example .env
#
#  y rellena los valores reales. NO commitees `.env` (contiene secretos).
#  docker compose sustituye automaticamente los ${VAR} de docker-compose.yml
#  con lo definido aqui.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
# Usuario administrador del cluster Postgres. No secreto (pero no lo publiques).
# Ejemplo: procovar
POSTGRES_USER=procovar

# Password del usuario Postgres. SECRETO. Usa una cadena larga y aleatoria.
# Ejemplo: kR9-x2LpQ7mZv4Tn8sB1
POSTGRES_PASSWORD=cambia-esto-por-una-clave-fuerte

# --- Clave de servicio compartida entre apps ---------------------------------
# SERVICE_API_KEY: clave interna que autentica las llamadas maquina-a-maquina
# (PEDIDO <-> delivery <-> worker). DEBE SER LA MISMA en PEDIDO y en delivery.
# SECRETO. Ejemplo: svc_9f3a1c7e5b2d4068a1c9e7f30b6d2a45
SERVICE_API_KEY=cambia-esto-clave-interna-compartida

# --- JWT (login de usuarios) -------------------------------------------------
# JWT_SECRET: firma los tokens de sesion de PEDIDO y de delivery. SECRETO.
# OJO: delivery FALLA al arrancar si esta vacio. Debe ser estable: si lo cambias,
# se cierran todas las sesiones abiertas. Usa una cadena larga y aleatoria.
# Ejemplo: jwt_7c1f9a2e8d4b60315a9c0e7f2b8d6a41
JWT_SECRET=cambia-esto-secreto-de-los-tokens

# --- Integracion con el Warehouse (peso/cotizacion) --------------------------
# WAREHOUSE_API_URL: URL base del servicio de warehouse que resuelve pesos.
# No secreto. Ejemplo: https://warehouse.tu-empresa.com
WAREHOUSE_API_URL=https://warehouse.ejemplo.com

# WAREHOUSE_API_TOKEN: token de autenticacion contra el warehouse. SECRETO.
# Ejemplo: whs_live_1a2b3c4d5e6f7g8h
WAREHOUSE_API_TOKEN=cambia-esto-token-del-warehouse

# --- Dominio publico (Caddy) -------------------------------------------------
# PUBLIC_DOMAIN: dominio raiz servido por Caddy. Caddy emite TLS para el y sus
# subdominios (delivery.*, analitics.*). Debe apuntar (DNS A/AAAA) al VPS.
# No secreto. Ejemplo: procovar.com
PUBLIC_DOMAIN=procovar.ejemplo.com
